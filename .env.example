# Pulse — Site Monitoring Tool
DATABASE_URL=postgresql://user:password@hostname:5432/pulse
PUBLIC_BASE_URL=http://localhost:3000

# Dashboard authentication
DASHBOARD_PASSWORD=your_secure_password_here
SESSION_SECRET=your_random_session_secret_here

# Telegram alerting (optional but recommended)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Slack alerting (optional)
SLACK_WEBHOOK_URL=

# Discord alerting (optional)
DISCORD_WEBHOOK_URL=

# Generic webhook alerting (optional)
WEBHOOK_URL=

# Email alerts via Resend (optional)
RESEND_API_KEY=
RESEND_FROM_EMAIL=you@example.com

# AI incident diagnosis (optional)
GEMINI_API_KEY=
