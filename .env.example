# Postgres connection string. A Supabase project's "Connection string" (URI,
# Session pooler or direct) from Settings -> Database works fine here.
DATABASE_URL="postgresql://user:password@host:5432/postgres"

# Port the dashboard/API server listens on.
PORT=3000

# Used to build absolute links in alert messages (e.g. the Telegram
# notification's "view incident" link). Set to your real deployed URL.
PUBLIC_BASE_URL="http://localhost:3000"

# Shared password protecting the whole dashboard (single-user auth).
DASHBOARD_PASSWORD="change-me"

# Random secret used to sign the session cookie. Generate with:
#   openssl rand -hex 32
SESSION_SECRET="change-me-too"

# --- Alerts (both optional; leave blank to disable) ---

# Telegram bot token from @BotFather, and the chat ID to send alerts to.
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# Generic outgoing webhook — Pulse POSTs a JSON payload on every
# incident open/resolve.
WEBHOOK_URL=""

# Optional: Gemini API key (https://aistudio.google.com/apikey) — when set,
# Pulse asks Gemini for a root-cause guess + ranked next steps once per
# opened incident, included in the alert and shown on the dashboard.
# Diagnosis-only — Pulse never takes automated action on your infrastructure.
GEMINI_API_KEY=""
